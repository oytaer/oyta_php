# OYTAPHP 环境配置文件
# 
# 本文件包含应用的敏感配置信息，不应提交到版本控制
# 复制此文件为 .env 并填写实际配置值
#
# 配置格式：KEY = value
# 配置值可以通过 env() 函数获取

# ==================== 应用配置 ====================

# 调试模式（生产环境请设为 false）
APP_DEBUG = true

# ==================== 数据库配置 ====================

[DATABASE]
# 数据库类型（mysql/pgsql/sqlite）
TYPE = mysql

# 数据库连接信息
HOST = 127.0.0.1
NAME = test
USER = root
PASS = 
PORT = 3306

# 字符集
CHARSET = utf8mb4

# 表前缀（如有）
PREFIX = 

# ==================== Redis配置 ====================

[REDIS]
HOST = 127.0.0.1
PORT = 6379
PASSWORD = 
