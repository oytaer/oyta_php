# OYTAPHP 环境配置示例文件
# 
# 本文件是环境配置的示例模板
# 使用方法：复制此文件为 .env 并修改配置值
#
# 注意：.env 文件包含敏感信息，不应提交到版本控制

# ==================== 应用配置 ====================

# 调试模式
# true: 显示详细错误信息（开发环境）
# false: 显示友好错误页面（生产环境）
APP_DEBUG = true

# ==================== 数据库配置 ====================

[DATABASE]
# 数据库类型
# 可选值：mysql、pgsql、sqlite
TYPE = mysql

# 数据库服务器地址
HOST = 127.0.0.1

# 数据库名称
NAME = test

# 数据库用户名
USER = root

# 数据库密码
PASS = 

# 数据库端口
# MySQL默认：3306
# PostgreSQL默认：5432
PORT = 3306

# 字符集
CHARSET = utf8mb4

# 表前缀（如果需要）
PREFIX = 

# ==================== Redis配置 ====================

[REDIS]
# Redis服务器地址
HOST = 127.0.0.1

# Redis端口
PORT = 6379

# Redis密码（如果没有设置密码，留空）
PASSWORD = 
